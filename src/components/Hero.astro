---
import site from '../data/site.json';
import WaIcon from './WaIcon.astro';
// variant: 1 split blanco | 2 full-bleed | 3 negro tipográfico
const { variant = 1 } = Astro.props;
const wa = `https://wa.me/${site.whatsapp}?text=Hola,%20quiero%20consultar%20por%20un%20service%20de%20bomba`;
---
{variant === 1 && (
<section style="background:#fff;border-bottom:1px solid #ebebe6;padding:56px 0 64px">
  <div class="wrap hero-grid">
    <div class="hero-content">
      <div class="eyebrow"><span class="sq"></span><span>SERVICE OFICIAL ROWA · GRUNDFOS</span></div>
      <h1 style="font-size:clamp(32px,4.6vw,52px);line-height:1.05;text-wrap:pretty">Service y reparación de bombas de agua en Pinamar</h1>
      <p style="margin:0;font-size:18px;line-height:1.6;color:#444;max-width:52ch;text-wrap:pretty">Especialistas en bombas Rowa y Grundfos. Diagnóstico, instalación, mantenimiento y reparación para hogares, comercios y propiedades de la Costa.</p>
      <div class="hero-actions">
        <a href={wa} target="_blank" rel="noopener" class="btn btn-primary"><WaIcon />Consultar por WhatsApp</a>
        <a href="#servicios" class="btn btn-outline">Ver servicios de bombas</a>
      </div>
      <div class="hero-meta">
        <span>✓ {site.zonas.join(' · ')}</span><span>✓ {site.hours}</span>
      </div>
    </div>
    <div class="hero-media">
      <img src="/assets/van.webp" alt="Vehículo de Martínez Gas-Plomería, service oficial Rowa y Grundfos, en Pinamar" class="hero-img">
      <div class="hero-badge">EN PINAMAR Y LA COSTA</div>
    </div>
  </div>
</section>
)}
{variant === 2 && (
<section style="position:relative;overflow:hidden;background:#111">
  <img src="/assets/van.webp" alt="" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.55">
  <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(10,10,10,.92) 0%,rgba(10,10,10,.55) 55%,rgba(10,10,10,.25) 100%)"></div>
  <div class="wrap" style="position:relative;padding:96px 20px 104px;display:flex;flex-direction:column;gap:20px">
    <div class="eyebrow"><span class="sq"></span><span style="color:var(--yellow)">SERVICE OFICIAL ROWA · GRUNDFOS</span></div>
    <h1 style="font-size:clamp(34px,5vw,58px);line-height:1.04;color:#fff;max-width:18ch;text-wrap:pretty">Service y reparación de bombas de agua en Pinamar</h1>
    <p style="margin:0;font-size:18px;line-height:1.6;color:rgba(255,255,255,.85);max-width:52ch;text-wrap:pretty">Especialistas en bombas Rowa y Grundfos. Diagnóstico, instalación, mantenimiento y reparación para hogares, comercios y propiedades de la Costa.</p>
    <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:8px">
      <a href={wa} target="_blank" rel="noopener" class="btn btn-primary"><WaIcon />Consultar por WhatsApp</a>
      <a href="#servicios" class="btn btn-outline-light">Ver servicios de bombas</a>
    </div>
  </div>
</section>
)}
{variant === 3 && (
<section style="background:#111;color:#fff;padding:72px 0 0">
  <div class="wrap" style="display:flex;flex-direction:column;gap:24px">
    <div style="display:flex;gap:10px;flex-wrap:wrap">
      <span class="tag">SERVICE OFICIAL ROWA</span>
      <span style="background:#fff;color:#111;font-family:ui-monospace,monospace;font-size:11px;font-weight:700;letter-spacing:.1em;padding:7px 12px">SERVICE OFICIAL GRUNDFOS</span>
    </div>
    <h1 style="font-size:clamp(38px,6vw,72px);line-height:1;text-wrap:pretty">¿Tu bomba no arranca, hace ruido o <span style="color:var(--yellow)">perdió presión</span>?</h1>
    <p style="margin:0;font-size:18px;line-height:1.6;color:rgba(255,255,255,.75);max-width:56ch;text-wrap:pretty">Diagnosticamos, reparamos, instalamos y mantenemos bombas de agua y sistemas de presurización en Pinamar, Cariló, Valeria del Mar, Ostende y Costa Esmeralda.</p>
    <div style="display:flex;gap:12px;flex-wrap:wrap">
      <a href={wa} target="_blank" rel="noopener" class="btn btn-primary"><WaIcon />Consultar por WhatsApp</a>
      <a href="#servicios" class="btn btn-outline-light">Ver servicios de bombas</a>
    </div>
    <img src="/assets/van.webp" alt="Vehículo de Martínez Gas-Plomería en Pinamar" style="width:100%;border-radius:12px 12px 0 0;margin-top:16px">
  </div>
</section>
)}
