---
import site from '../data/site.json';
import WaIcon from './WaIcon.astro';
import InstagramIcon from './InstagramIcon.astro';
import { withBase } from '../lib/url.js';
const wa = `https://wa.me/${site.whatsapp}?text=Hola,%20quiero%20consultar%20por%20un%20service%20de%20bomba`;
const p = Astro.url.pathname;
const nav = [
  { href: '/', label: 'Inicio' },
  { href: '/service-bombas-rowa-pinamar/', label: 'Service Rowa' },
  { href: '/trabajos/', label: 'Trabajos' },
  { href: '/#zonas', label: 'Zonas' },
  { href: '/#plomeria-gas', label: 'Plomería y Gas' },
  { href: '/contacto/', label: 'Contacto' },
];
---
<header class="site-header">
  <div class="wrap header-bar">
    <input type="checkbox" id="nav-toggle" class="nav-toggle-input">
    <label for="nav-toggle" class="nav-toggle" aria-label="Abrir menú"><span></span><span></span><span></span></label>
    <a href={withBase('/')} class="header-logo"><img src={withBase('/assets/logo_vectorizado.svg')} alt={site.name}></a>
    <nav class="header-nav">
      {nav.map(n => (
        <a href={withBase(n.href)} class:list={['header-link', { active: p === withBase(n.href) }]}>{n.label}</a>
      ))}
      <div class="header-actions">
        <a href={wa} target="_blank" rel="noopener" class="btn btn-primary"><WaIcon size={16} />WhatsApp</a>
        <a href={`https://instagram.com/${site.instagram}`} target="_blank" rel="noopener" aria-label="Instagram" class="header-ig"><InstagramIcon size={20} fill="#fff" /></a>
      </div>
    </nav>
  </div>
</header>
