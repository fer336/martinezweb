---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingWa from '../components/FloatingWa.astro';
import site from '../data/site.json';
import { withBase } from '../lib/url.js';

const {
  title,
  description,
  path = Astro.url.pathname,
  ogImage = withBase('/assets/logo.png'),
  jsonld = null,
} = Astro.props;

const canonical = new URL(path, Astro.site).toString();

// LocalBusiness (Plumber) — se incluye en todas las páginas
const business = {
  '@context': 'https://schema.org',
  '@type': 'Plumber',
  name: site.name,
  image: new URL(ogImage, Astro.site).toString(),
  description: 'Service oficial Rowa y Grundfos. Reparación, instalación y mantenimiento de bombas de agua en Pinamar y la Costa.',
  telephone: site.phoneIntl,
  url: Astro.site?.toString(),
  areaServed: site.zonas,
  address: { '@type': 'PostalAddress', addressLocality: site.locality, addressRegion: site.region, addressCountry: site.country },
  openingHours: site.openingHours,
  priceRange: '$$',
  knowsAbout: ['Bombas Rowa', 'Bombas Grundfos', 'Bombas presurizadoras', 'Plomería', 'Gas'],
  aggregateRating: { '@type': 'AggregateRating', ratingValue: site.ratingValue, reviewCount: site.reviewCount },
};
---
<!doctype html>
<html lang="es-AR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
  <meta property="og:image:width" content="1698" />
  <meta property="og:image:height" content="926" />
  <meta property="og:image:alt" content={site.name} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content="es_AR" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />
  <link rel="icon" href={withBase('/favicon.ico')} sizes="any" />
  <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
  <link rel="apple-touch-icon" href={withBase('/apple-touch-icon.png')} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Public+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify(business)} />
  {jsonld && <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />}
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
  <FloatingWa />
</body>
</html>
