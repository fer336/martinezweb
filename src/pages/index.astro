---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FinalCta from '../components/FinalCta.astro';
import Faq from '../components/Faq.astro';
import WaIcon from '../components/WaIcon.astro';
import site from '../data/site.json';
import problemas from '../data/problemas.json';
import servicios from '../data/servicios.json';
import pasos from '../data/pasos.json';
import resenas from '../data/resenas.json';
import faqs from '../data/faqs.json';

// Elegí la variante de hero: 1 split | 2 full-bleed | 3 negro tipográfico
const HERO = 1;

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
const wa = `https://wa.me/${site.whatsapp}?text=Hola,%20quiero%20consultar%20por%20un%20service%20de%20bomba`;
---
<BaseLayout
  title="Service de bombas de agua en Pinamar · Martínez Gas-Plomería"
  description="Service oficial Rowa y Grundfos. Reparación, instalación y mantenimiento de bombas de agua en Pinamar, Cariló y la Costa."
  jsonld={faqJsonLd}
>
  <Hero variant={HERO} />

  <section style="background:var(--bg)">
    <div class="wrap" style="display:flex;flex-direction:column;gap:28px">
      <div style="display:flex;flex-direction:column;gap:10px">
        <div class="eyebrow"><span class="sq"></span><span>PROBLEMAS QUE RESOLVEMOS</span></div>
        <h2 class="h2">¿Reconocés alguno de estos síntomas?</h2>
      </div>
      <div class="grid-3">
        {problemas.map(p => (
          <div class="card" style="display:flex;flex-direction:column;gap:8px">
            <span style="font-family:ui-monospace,monospace;font-size:12px;font-weight:700;color:var(--yellow-ink)">{p.num}</span>
            <strong style="font-size:16.5px">{p.t}</strong>
            <span style="font-size:14px;line-height:1.55;color:#555">{p.d}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="servicios" style="scroll-margin-top:80px">
    <div class="wrap" style="display:flex;flex-direction:column;gap:28px">
      <div style="display:flex;flex-direction:column;gap:10px">
        <div class="eyebrow"><span class="sq"></span><span>SERVICIOS DE BOMBAS</span></div>
        <h2 class="h2">Servicios principales</h2>
        <div style="display:inline-flex;align-items:center;gap:8px;background:var(--yellow);color:#111;font-weight:800;font-size:13.5px;padding:9px 16px;border-radius:999px;align-self:flex-start">6 meses de garantía en reparación y recambio completo de equipo</div>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px">
        {servicios.map(s => (
          <a href={`/${s.slug}/`} style={`border-radius:12px;padding:26px;display:flex;flex-direction:column;gap:10px;transition:all .2s;${s.oficial?'background:#111;color:#fff':'background:#fff;border:1px solid var(--border)'}`}>
            {s.oficial && <span class="tag">SERVICE OFICIAL</span>}
            <strong style="font-family:var(--font-display);font-size:21px">{s.t}</strong>
            <span style={`font-size:14.5px;line-height:1.55;${s.oficial?'color:rgba(255,255,255,.7)':'color:#555'}`}>{s.d}</span>
            <span style={`font-weight:700;font-size:14px;margin-top:auto;${s.oficial?'color:var(--yellow)':'color:var(--yellow-ink)'}`}>Ver página →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section style="background:#111;color:#fff">
    <div class="wrap" style="display:flex;flex-direction:column;gap:32px">
      <div style="display:flex;flex-direction:column;gap:10px">
        <div class="eyebrow"><span class="sq"></span><span style="color:var(--yellow)">CÓMO TRABAJAMOS</span></div>
        <h2 class="h2">Del primer mensaje a la prueba final</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:14px">
        {pasos.map(p => (
          <div style="border:1px solid rgba(255,255,255,.14);border-radius:12px;padding:20px;display:flex;flex-direction:column;gap:10px">
            <span style="font-family:var(--font-display);font-size:28px;font-weight:700;color:var(--yellow)">{p.num}</span>
            <strong style="font-size:16px">{p.t}</strong>
            <span style="font-size:13.5px;line-height:1.5;color:rgba(255,255,255,.65)">{p.d}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section style="background:var(--bg)">
    <div class="wrap" style="display:flex;flex-direction:column;gap:28px">
      <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;flex-wrap:wrap">
        <div style="display:flex;flex-direction:column;gap:10px">
          <div class="eyebrow"><span class="sq"></span><span>RESEÑAS DE GOOGLE</span></div>
          <h2 class="h2">Lo que dicen los clientes</h2>
        </div>
        <div style="display:flex;gap:10px;flex-wrap:wrap">
          <a href={site.googleUrl} target="_blank" rel="noopener" class="btn btn-outline" style="font-size:14px;padding:11px 18px">Ver todas en Google</a>
          <a href={`https://search.google.com/local/writereview?placeid=${site.placeId}`} target="_blank" rel="noopener" class="btn btn-primary" style="font-size:14px;padding:12px 18px">Dejanos tu reseña</a>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:16px">
        {resenas.map(r => (
          <div style="background:#fff;border:1px solid var(--border);border-radius:12px;padding:24px;display:flex;flex-direction:column;gap:12px">
            <span style="color:var(--yellow);font-size:16px;letter-spacing:2px">★★★★★</span>
            <p style="margin:0;font-size:14.5px;line-height:1.6;color:#333;text-wrap:pretty">"{r.q}"</p>
            <div style="display:flex;align-items:baseline;gap:8px;margin-top:auto">
              <strong style="font-size:13.5px">{r.n}</strong><span style="font-size:12.5px;color:#888">{r.f}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="zonas" style="scroll-margin-top:80px">
    <div class="wrap" style="display:flex;flex-direction:column;gap:24px">
      <div style="display:flex;flex-direction:column;gap:10px">
        <div class="eyebrow"><span class="sq"></span><span>ZONAS DE ATENCIÓN</span></div>
        <h2 class="h2">Atendemos en toda la Costa</h2>
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <a href="/contacto/" class="pill">Pinamar</a>
        <a href="/zonas/valeria-del-mar/" class="pill">Valeria del Mar</a>
        <a href="/zonas/ostende/" class="pill">Ostende</a>
        <a href="/zonas/carilo/" class="pill">Cariló</a>
        <a href="/zonas/costa-esmeralda/" class="pill">Costa Esmeralda</a>
      </div>
    </div>
  </section>

  <section id="plomeria-gas" style="background:var(--bg);padding:56px 0;scroll-margin-top:80px">
    <div class="wrap" style="display:flex;flex-direction:column;gap:28px">
      <div style="display:flex;flex-direction:column;gap:10px">
        <div class="eyebrow"><span class="sq"></span><span>PLOMERÍA Y GAS</span></div>
        <h2 class="h2">También hacemos plomería y gas</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px">
        <div style="background:#fff;border:1px solid var(--border);border-radius:12px;padding:26px;display:flex;flex-direction:column;gap:8px">
          <span style="font-family:ui-monospace,monospace;font-size:11px;font-weight:700;letter-spacing:.12em;color:#888">PLOMERÍA</span>
          <strong style="font-family:var(--font-display);font-size:20px">Personal matriculado</strong>
          <span style="font-size:14.5px;line-height:1.55;color:#555">Instalación y reparación de artefactos, cañerías y conexiones. Trabajos domiciliarios y de obra.</span>
        </div>
        <div style="background:#fff;border:1px solid var(--border);border-radius:12px;padding:26px;display:flex;flex-direction:column;gap:8px">
          <span style="font-family:ui-monospace,monospace;font-size:11px;font-weight:700;letter-spacing:.12em;color:#888">GAS</span>
          <strong style="font-family:var(--font-display);font-size:20px">Instalaciones y reparaciones</strong>
          <span style="font-size:14.5px;line-height:1.55;color:#555">Trabajos de gas para hogares y comercios de la zona, coordinados junto al resto de la instalación.</span>
        </div>
      </div>
    </div>
  </section>

  <section><Faq items={faqs} /></section>

  <FinalCta />
</BaseLayout>
