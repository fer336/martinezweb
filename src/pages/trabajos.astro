---
import BaseLayout from '../layouts/BaseLayout.astro';
import FinalCta from '../components/FinalCta.astro';

interface TrabajoImagen {
  url: string;
  etiqueta: 'antes' | 'despues' | null;
}

interface Trabajo {
  id: number;
  categoria: string;
  titulo: string;
  imagenes: TrabajoImagen[];
}

const apiUrl = import.meta.env.PUBLIC_API_URL;
let trabajos: Trabajo[] = [];
if (apiUrl) {
  try {
    const res = await fetch(`${apiUrl}/trabajos`);
    if (res.ok) trabajos = await res.json();
  } catch {
    // La API no respondió durante el build: se muestra la sección vacía en vez de romper el sitio.
  }
}
---
<BaseLayout
  title="Trabajos realizados · Martínez Gas-Plomería Pinamar"
  description="Antes y después de reparaciones de bombas, y trabajos de plomería y gas realizados en Pinamar y la Costa."
>
  <section style="padding-bottom:0">
    <div class="wrap" style="display:flex;flex-direction:column;gap:10px">
      <div class="eyebrow"><span class="sq"></span><span>TRABAJOS REALIZADOS</span></div>
      <h1 style="font-size:clamp(30px,4.4vw,46px);line-height:1.08;text-wrap:pretty">Trabajos realizados</h1>
      <p style="margin:0;font-size:17px;line-height:1.6;color:#444;max-width:60ch;text-wrap:pretty">Así dejamos cada reparación de bombas, instalación de plomería y trabajo de gas en Pinamar y la Costa.</p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="work-grid">
        {trabajos.map(t => (
          <div class="work-card">
            <div class="work-gallery">
              {t.imagenes.map((img, i) => (
                <div class:list={['work-slide', i === 0 && 'is-active']}>
                  <img
                    src={img.url}
                    alt={img.etiqueta === 'antes' ? `Antes: ${t.titulo}` : img.etiqueta === 'despues' ? `Después: ${t.titulo}` : t.titulo}
                    loading="lazy"
                  >
                  {img.etiqueta && <span class="badge">{img.etiqueta === 'antes' ? 'ANTES' : 'DESPUÉS'}</span>}
                </div>
              ))}
            </div>
            <div class="work-info">
              <span style="font-family:ui-monospace,monospace;font-size:10.5px;font-weight:700;letter-spacing:.1em;color:var(--yellow-ink)">{t.categoria.toUpperCase()}</span>
              <strong style="font-size:15.5px">{t.titulo}</strong>
            </div>
          </div>
        ))}
        {trabajos.length === 0 && (
          <p style="color:#888;font-size:14.5px">Estamos cargando las fotos de los últimos trabajos — volvé a pasar pronto.</p>
        )}
      </div>
    </div>
  </section>

  <FinalCta />
</BaseLayout>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduceMotion) {
    const galleries = document.querySelectorAll<HTMLElement>('.work-gallery');
    setInterval(() => {
      galleries.forEach((gallery) => {
        const slides = gallery.querySelectorAll<HTMLElement>('.work-slide');
        if (slides.length < 2) return;
        const activeIndex = [...slides].findIndex((s) => s.classList.contains('is-active'));
        slides[activeIndex]?.classList.remove('is-active');
        slides[(activeIndex + 1) % slides.length].classList.add('is-active');
      });
    }, 2000);
  }
</script>
