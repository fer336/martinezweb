---
import BaseLayout from '../layouts/BaseLayout.astro';
import FinalCta from '../components/FinalCta.astro';

interface TrabajoImagen {
  url: string;
  etiqueta: 'antes' | 'despues' | null;
}

interface Trabajo {
  id: number;
  categoria: string;
  titulo: string;
  imagenes: TrabajoImagen[];
}

const apiUrl = import.meta.env.PUBLIC_API_URL;
let trabajos: Trabajo[] = [];
if (apiUrl) {
  try {
    const res = await fetch(`${apiUrl}/trabajos`);
    if (res.ok) {
      const data = (await res.json()) as Trabajo[];
      // Si el backend está a mitad de un redeploy puede devolver una forma
      // vieja/inesperada; filtramos en vez de romper el build del sitio.
      trabajos = data.filter((t) => Array.isArray(t.imagenes) && t.imagenes.length > 0);
    }
  } catch {
    // La API no respondió durante el build: se muestra la sección vacía en vez de romper el sitio.
  }
}
---
<BaseLayout
  title="Trabajos realizados · Martínez Gas-Plomería Pinamar"
  description="Antes y después de reparaciones de bombas, y trabajos de plomería y gas realizados en Pinamar y la Costa."
>
  <section style="padding-bottom:0">
    <div class="wrap" style="display:flex;flex-direction:column;gap:10px">
      <div class="eyebrow"><span class="sq"></span><span>TRABAJOS REALIZADOS</span></div>
      <h1 style="font-size:clamp(30px,4.4vw,46px);line-height:1.08;text-wrap:pretty">Trabajos realizados</h1>
      <p style="margin:0;font-size:17px;line-height:1.6;color:#444;max-width:60ch;text-wrap:pretty">Así dejamos cada reparación de bombas, instalación de plomería y trabajo de gas en Pinamar y la Costa.</p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="work-grid">
        {trabajos.map(t => (
          <div class="work-card">
            <button type="button" class="work-gallery" data-imagenes={JSON.stringify(t.imagenes)} data-titulo={t.titulo} aria-label={`Ver fotos de ${t.titulo} en grande`}>
              {t.imagenes.map((img, i) => (
                <div class:list={['work-slide', i === 0 && 'is-active']}>
                  <img
                    src={img.url}
                    alt={img.etiqueta === 'antes' ? `Antes: ${t.titulo}` : img.etiqueta === 'despues' ? `Después: ${t.titulo}` : t.titulo}
                    loading="lazy"
                  >
                  {img.etiqueta && <span class="badge">{img.etiqueta === 'antes' ? 'ANTES' : 'DESPUÉS'}</span>}
                </div>
              ))}
            </button>
            <div class="work-info">
              <span style="font-family:ui-monospace,monospace;font-size:10.5px;font-weight:700;letter-spacing:.1em;color:var(--yellow-ink)">{t.categoria.toUpperCase()}</span>
              <strong style="font-size:15.5px">{t.titulo}</strong>
            </div>
          </div>
        ))}
        {trabajos.length === 0 && (
          <p style="color:#888;font-size:14.5px">Estamos cargando las fotos de los últimos trabajos — volvé a pasar pronto.</p>
        )}
      </div>
    </div>
  </section>

  <FinalCta />

  <dialog id="lightbox" class="lightbox">
    <button type="button" class="lightbox-close" aria-label="Cerrar">✕</button>
    <button type="button" class="lightbox-nav lightbox-prev" aria-label="Foto anterior">‹</button>
    <div class="lightbox-stage">
      <img id="lightbox-img" alt="">
      <span id="lightbox-badge" class="badge"></span>
    </div>
    <button type="button" class="lightbox-nav lightbox-next" aria-label="Foto siguiente">›</button>
    <p id="lightbox-counter" class="lightbox-counter"></p>
  </dialog>
</BaseLayout>

<script>
  interface TrabajoImagen {
    url: string;
    etiqueta: 'antes' | 'despues' | null;
  }

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const galleries = document.querySelectorAll<HTMLElement>('.work-gallery');
  const paused = new Set<HTMLElement>();

  if (!reduceMotion) {
    galleries.forEach((gallery) => {
      gallery.addEventListener('mouseenter', () => paused.add(gallery));
      gallery.addEventListener('mouseleave', () => paused.delete(gallery));
    });
    setInterval(() => {
      galleries.forEach((gallery) => {
        if (paused.has(gallery)) return;
        const slides = gallery.querySelectorAll<HTMLElement>('.work-slide');
        if (slides.length < 2) return;
        const activeIndex = [...slides].findIndex((s) => s.classList.contains('is-active'));
        slides[activeIndex]?.classList.remove('is-active');
        slides[(activeIndex + 1) % slides.length].classList.add('is-active');
      });
    }, 2000);
  }

  const lightbox = document.getElementById('lightbox') as HTMLDialogElement | null;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const lightboxBadge = document.getElementById('lightbox-badge');
  const lightboxCounter = document.getElementById('lightbox-counter');
  const prevBtn = lightbox?.querySelector<HTMLButtonElement>('.lightbox-prev');
  const nextBtn = lightbox?.querySelector<HTMLButtonElement>('.lightbox-next');
  const closeBtn = lightbox?.querySelector<HTMLButtonElement>('.lightbox-close');

  if (lightbox && lightboxImg && lightboxBadge && lightboxCounter && prevBtn && nextBtn && closeBtn) {
    let imagenes: TrabajoImagen[] = [];
    let titulo = '';
    let index = 0;

    function render() {
      const img = imagenes[index];
      lightboxImg!.src = img.url;
      lightboxImg!.alt =
        img.etiqueta === 'antes' ? `Antes: ${titulo}` : img.etiqueta === 'despues' ? `Después: ${titulo}` : titulo;
      lightboxBadge!.textContent = img.etiqueta === 'antes' ? 'ANTES' : img.etiqueta === 'despues' ? 'DESPUÉS' : '';
      lightboxBadge!.hidden = !img.etiqueta;
      const multiple = imagenes.length > 1;
      prevBtn!.hidden = !multiple;
      nextBtn!.hidden = !multiple;
      lightboxCounter!.hidden = !multiple;
      lightboxCounter!.textContent = `${index + 1} / ${imagenes.length}`;
    }

    galleries.forEach((gallery) => {
      gallery.addEventListener('click', () => {
        imagenes = JSON.parse(gallery.dataset.imagenes || '[]');
        titulo = gallery.dataset.titulo || '';
        const slides = gallery.querySelectorAll<HTMLElement>('.work-slide');
        index = Math.max(0, [...slides].findIndex((s) => s.classList.contains('is-active')));
        render();
        lightbox.showModal();
      });
    });

    prevBtn.addEventListener('click', () => {
      index = (index - 1 + imagenes.length) % imagenes.length;
      render();
    });
    nextBtn.addEventListener('click', () => {
      index = (index + 1) % imagenes.length;
      render();
    });
    closeBtn.addEventListener('click', () => lightbox.close());
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) lightbox.close();
    });
    lightbox.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') prevBtn.click();
      if (e.key === 'ArrowRight') nextBtn.click();
    });
  }
</script>
